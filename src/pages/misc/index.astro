---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';
import FormattedDate from '../../components/FormattedDate.astro';
import { Image } from 'astro:assets';

// Discover markdown files within each subfolder of /src/pages/misc
// Prefer `post.md` if present, otherwise pick the first `.md` file found.
const mdModules = import.meta.glob('/src/pages/misc/*/*.md', { eager: true });

// Import images from each subfolder with their image objects
const imageModules = import.meta.glob('/src/pages/misc/*/*.{png,jpg,jpeg}', { 
	eager: true
});

// Map images by folder
const imagesByFolder: Record<string, Record<string, any>> = {};
for (const path in imageModules) {
	const match = path.match(/\/src\/pages\/misc\/([^\/]+)\/([^\/]+\.(png|jpg|jpeg))$/);
	if (!match) continue;
	const folder = match[1];
	const filename = match[2];
	imagesByFolder[folder] ??= {};
	imagesByFolder[folder][filename] = (imageModules[path] as any).default;
}

const grouped = /** @type {Record<string, any[]>} */ ({});
for (const path in mdModules) {
	const m = mdModules[path];
	const match = path.match(/\/?src\/pages\/misc\/([^\/]+)\/([^\/]+\.md)$/);
	if (!match) continue;
	const folder = match[1];
	grouped[folder] ??= [];
	grouped[folder].push({ path, mod: m });
}

const posts = Object.keys(grouped)
	.map((folder) => {
		const items = grouped[folder];
		let pick = items.find((it: any) => it.path.endsWith('/post.md')) ?? items[0];
		const fm = pick.mod.frontmatter ?? pick.mod;
		let heroImage = fm.heroImage ?? fm.hero_image ?? fm.image ?? null;
		
		// Resolve relative image paths using imported images
		if (heroImage && heroImage.startsWith('./')) {
			const filename = heroImage.slice(2);
			heroImage = imagesByFolder[folder]?.[filename] ?? null;
		}
		
		return {
			title: fm.title ?? folder,
			date: fm.pubDate ? new Date(fm.pubDate) : new Date(0),
			description: fm.description ?? fm.excerpt ?? '',
			heroImage: heroImage,
			route: `/misc/${folder}/`,
			slug: folder,
		};
	})
	.sort((a, b) => b.date.getTime() - a.date.getTime());
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 960px;
			}
			ul {
				display: flex;
				flex-wrap: wrap;
				gap: 2rem;
				list-style-type: none;
				margin: 0;
				padding: 0;
			}
			ul li {
				width: calc(50% - 1rem);
			}
			ul li * {
				text-decoration: none;
				transition: 0.2s ease;
			}
			ul li:first-child {
				width: 100%;
				margin-bottom: 1rem;
				text-align: center;
			}
			ul li:first-child img,
			ul li:first-child picture img {
				width: 100%;
			}
			ul li:first-child .title {
				font-size: 2.369rem;
			}
			.image-container {
				aspect-ratio: 720 / 360;
				overflow: hidden;
				margin-bottom: 0.5rem;
				border-radius: 12px;
			}
			.image-container img,
			.image-container picture img {
				width: 100%;
				height: 100%;
				object-fit: cover;
				display: block;
			}
			ul li img,
			ul li picture,
			ul li picture img {
				margin-bottom: 0.5rem;
				border-radius: 12px;
				display: block;
				max-width: 100%;
				height: auto;
			}
			ul li a {
				display: block;
			}
			.title {
				margin: 0;
				color: rgb(var(--black));
				line-height: 1;
			}
			.date {
				margin: 0;
				color: rgb(var(--gray));
			}
			ul li a:hover h4,
			ul li a:hover .date {
				color: rgb(var(--accent));
			}
			ul a:hover img {
				box-shadow: var(--box-shadow);
			}
			ul a:hover picture img {
				box-shadow: var(--box-shadow);
			}
			ul a:hover .image-container {
				box-shadow: var(--box-shadow);
			}
			@media (max-width: 720px) {
				ul {
					gap: 0.5em;
				}
				ul li {
					width: 100%;
					text-align: center;
				}
				ul li:first-child {
					margin-bottom: 0;
				}
				ul li:first-child .title {
					font-size: 1.563em;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main  transition:animate="slide">
			<section>
				<ul>
					{
						posts.map((post) => (
							<li>
								<a href={post.route}>
									{post.heroImage ? (
										<div class="image-container">
											<Image width={720} height={360} src={post.heroImage} alt={post.title} />
										</div>
									) : null}
									<h4 class="title">{post.title}</h4>
									<p class="date">
										<FormattedDate date={post.date} />
									</p>
								</a>
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>
